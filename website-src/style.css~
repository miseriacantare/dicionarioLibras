:root {
	--text: white;
	--border: #8b0418;
	--accent: #8b0418;
	--bg: black;
	--gradientBottom: black;
	--gradientTop: rgb(23, 2, 0);
	a:link {color: red;}

}
header {
	background: (url "images/newheader.png");
}

* {box-sizing: border-box;}

body {
	padding: 10px;
	font-family 'MS PGothic', serif;
	color: var(--text);
	/*background-image: url("images/firewalkwithme.png");*/
	background-color: var(--gradientTop);
	background-size: 1080px 1920px;
	background-position: 0 0, 0 0. 10px 18px, 0 0, 10px 18px;
}

.container {
	max-width: 90rem;
	margin: 5vw auto 12px auto;
	border: 10px ridge var(--border);
	outline: 3px solid var(--border);
	outline-offset: 4px;
	border-radius: 15px;
	display: flex;
	flex-wrap: wrap;
	padding: 5px;
	gap: 5px;

	background-color: var(--gradientBottom);
}

.small {flex: 1 1 9%;}
.large {flex: 1 1 60%;}
.full {flex: 1 1 100%;}
.half {flex: 1 1 39%;}
.winamp {flex: 1 1 100%}

header {
	background-image: url("images/newheader.png");
	background-size: cover;
	background position: center;
	width: 100%;
	height: 300px;
	position: relative;
}

header span {
	font-size: 2.5rem;
	position: absolute;
	bottom: 0;
	right: 10px;
	margin: 5px;
	font-weight: bold;
	text-shadow: 1px 1px var(--text), -1px 1px var(--text),
		     1px -1px var(--accent), -1px -1px var(--accent);
		     color: var(--gradientTop;)
}

nav {
	border: 5px ridge var(--border);
	border-radius: 5px;
	padding: 10px;
	margin: 10px 10px 5px 10px;
	background: linear-gradient(var(--gradientTop), var(--gradientBottom));
}

nav div {
	text-align: center;
	font-size: 1.25rem;
	margin: 5px 5px 10px 5px;
}

a {
	display: block;
	margin: 10px;
	background: linear-gradient(to right, var(--bg), var(--gradienBottom));
	border-radius: 10px;
	border: 5px ridge var(--border);
	padding: 2px 7px;
	text-decoration: none;
}


nav a:link{
	color: var(--text);}
 	a:visited{
	color: red;
}

winamp a:link{
	border = none;
}

a:hover {
	background: linear-gradient(to right,var(--bg),var(--gradientTop), var(--gradientTop));
}
a:focus{
	background: linear-gradient(to left,var(--bg),var(--gradientTop), var(--gradientTop));
}

div.small > img {
	display: block;
	margin: 5px 5px 5px 5px;
	border: 5px ridge var(--border);
	border-radius: 5px;
}

.small img {
	margin: auto;	
}

section {
	border: 5px ridge var(--border);
	border-radius: 5px;
	background: linear-gradient(var(--gradientTop), var(--gradientBottom));
	padding: 15px 10px 5px 15px;
	margin: 10px 5px 5px 10px;
}

.winamp > a:is(:link,:visited,:hover, :active) {
	border = none;
}

